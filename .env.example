# ──────────────────────────────────────────────────────────────────────────────
# Fintech Split System — variáveis de ambiente
# Copie para .env e preencha com seus valores reais
# ──────────────────────────────────────────────────────────────────────────────

# ── Aplicação ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ── Banco de dados (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fintech_split
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20

# ── AWS / SQS ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Em dev, aponta para o LocalStack. Em produção, use a URL real da AWS.
SQS_ENDPOINT=http://localstack:4566
SQS_QUEUE_URL=http://localstack:4566/000000000000/fintech-payments.fifo
SQS_DLQ_QUEUE_URL=http://localstack:4566/000000000000/fintech-payments-dlq.fifo
MAX_SQS_RECEIVE_COUNT=5

# ── Assinatura de webhook ──────────────────────────────────────────────────────
# Modo: "hmac" para dev/sandbox, "ecdsa" para produção
SIGNATURE_MODE=hmac
WEBHOOK_HMAC_SECRET=local-dev-secret

# Em produção com SIGNATURE_MODE=ecdsa, forneça a chave pública da Stark Bank
# STARK_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Stark Bank ────────────────────────────────────────────────────────────────
# Obtenha em: https://sandbox.starkbank.com → Configurações → Projetos
STARK_ENV=sandbox
STARK_PROJECT_ID=seu-project-id-aqui
STARK_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
cole-sua-chave-privada-aqui
-----END EC PRIVATE KEY-----"

# ── Conta do licenciado (recebe 98% de cada pagamento) ────────────────────────
LICENSED_NAME=Nome do Licenciado
LICENSED_TAX_ID=000.000.000-00
LICENSED_BANK_CODE=001
LICENSED_BRANCH_CODE=0001
LICENSED_ACCOUNT_NUMBER=000000-0
LICENSED_ACCOUNT_TYPE=checking

# ── Conta da holding (recebe 2% de cada pagamento) ────────────────────────────
HOLDING_NAME=Nome da Holding
HOLDING_TAX_ID=00.000.000/0001-00
HOLDING_BANK_CODE=001
HOLDING_BRANCH_CODE=0001
HOLDING_ACCOUNT_NUMBER=000000-1
HOLDING_ACCOUNT_TYPE=checking
