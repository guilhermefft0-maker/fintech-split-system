{
    "name": "fintech-split-system",
    "version": "1.0.0",
    "description": "Fintech payment split system Ã¢â‚¬â€ Stark Bank webhook processing with SQS queue, idempotency and financial ledger",
    "scripts": {
        "dev:webhook": "ts-node-dev --respawn --transpile-only src/webhook/server.ts",
        "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/payment.worker.ts",
        "build": "tsc",
        "start:webhook": "node dist/webhook/server.js",
        "start:worker": "node dist/worker/payment.worker.js",
        "migrate": "ts-node src/database/migrate.ts",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint 'src/**/*.ts'",
        "up": "docker compose up -d --build",
        "down": "docker compose down",
        "logs": "docker compose logs -f",
        "logs:webhook": "docker compose logs -f webhook",
        "logs:worker": "docker compose logs -f worker",
        "simulate": "powershell -ExecutionPolicy Bypass -File scripts/simulate-webhook.ps1"
    },
    "dependencies": {
        "@aws-sdk/client-sqs": "^3.540.0",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "pg": "^8.11.5",
        "pino": "^8.19.0",
        "pino-pretty": "^11.0.0",
        "starkbank": "^2.8.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.12.5",
        "@types/pg": "^8.11.5",
        "@typescript-eslint/eslint-plugin": "^7.7.0",
        "@typescript-eslint/parser": "^7.7.0",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}
